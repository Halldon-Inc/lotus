// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          String   @default("SALES") // ADMIN, MANAGER, SALES, PROCUREMENT, OPERATIONS
  avatar        String?
  department    String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  assignedClients   Client[]       @relation("AssignedRep")
  createdRequests   Request[]      @relation("RequestCreator")
  assignedRequests  Request[]      @relation("RequestAssignee")
  createdQuotes     Quote[]        @relation("QuoteCreator")
  verifiedPOs       PurchaseOrder[] @relation("POVerifier")
  sourcedItems      PurchaseOrderItem[] @relation("ItemSourcer")
  purchasedItems    PurchaseOrderItem[] @relation("ItemPurchaser")
  alerts            Alert[]
  activityLogs      ActivityLog[]
  notes             Note[]
  approvalRules     ApprovalRule[]     @relation("ApprovalRuleApprover")
  approvalRequests  ApprovalRequest[]  @relation("ApprovalRequester")
  approvalDecisions ApprovalRequest[]  @relation("ApprovalApprover")
  reportedDiscrepancies Discrepancy[]  @relation("DiscrepancyReporter")
  resolvedDiscrepancies Discrepancy[]  @relation("DiscrepancyResolver")

  @@map("users")
}

model Client {
  id              String   @id @default(cuid())
  name            String
  type            String   // SCHOOL, GOVERNMENT, HEALTHCARE, NONPROFIT, CORPORATE
  address         String?
  city            String?
  state           String?
  zip             String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  fiscalYearStart DateTime?
  spendingLimit   Float?
  hubspotId       String?
  assignedRepId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  assignedRep     User?           @relation("AssignedRep", fields: [assignedRepId], references: [id])
  requests        Request[]
  quotes          Quote[]
  purchaseOrders  PurchaseOrder[]
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  clientInvoices  ClientInvoice[]

  @@map("clients")
}

model Request {
  id            String   @id @default(cuid())
  clientId      String
  assignedToId  String?
  createdById   String
  subject       String
  description   String
  source        String   @default("MANUAL") // EMAIL, MANUAL, HUBSPOT
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status        String   @default("NEW") // NEW, ASSIGNED, IN_PROGRESS, QUOTED, CLOSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  client        Client   @relation(fields: [clientId], references: [id])
  assignedTo    User?    @relation("RequestAssignee", fields: [assignedToId], references: [id])
  createdBy     User     @relation("RequestCreator", fields: [createdById], references: [id])
  quotes        Quote[]

  @@map("requests")
}

model Quote {
  id            String   @id @default(cuid())
  requestId     String
  clientId      String
  createdById   String
  quoteNumber   String   @unique
  totalAmount   Float    @default(0)
  status        String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  validUntil    DateTime?
  sentAt        DateTime?
  hubspotQuoteId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  request       Request     @relation(fields: [requestId], references: [id])
  client        Client      @relation(fields: [clientId], references: [id])
  createdBy     User        @relation("QuoteCreator", fields: [createdById], references: [id])
  lineItems     QuoteLineItem[]
  purchaseOrder PurchaseOrder?

  @@map("quotes")
}

model QuoteLineItem {
  id            String   @id @default(cuid())
  quoteId       String
  productName   String
  description   String?
  specifications String?  // JSON string for color, size, material, etc.
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  sourceUrl     String?
  vendorName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  purchaseOrderItems PurchaseOrderItem[]

  @@map("quote_line_items")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  quoteId         String   @unique
  clientId        String
  poNumber        String
  totalAmount     Float
  status          String   @default("RECEIVED") // RECEIVED, VERIFIED, NEEDS_CORRECTION, RESUBMITTED, IN_PURCHASING, PARTIALLY_FULFILLED, FULFILLED, DELIVERED
  receivedAt      DateTime @default(now())
  verifiedById    String?
  discrepancyNotes String?
  scheduledDeliveryDate DateTime?
  deliveryMethod  String?
  rejectionReason String?
  rejectionCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  quote           Quote             @relation(fields: [quoteId], references: [id])
  client          Client            @relation(fields: [clientId], references: [id])
  verifiedBy      User?             @relation("POVerifier", fields: [verifiedById], references: [id])
  items           PurchaseOrderItem[]
  invoices        Invoice[]
  matchRecords    MatchRecord[]
  discrepancies   Discrepancy[]
  shipments       Shipment[]
  clientInvoices  ClientInvoice[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                    String   @id @default(cuid())
  purchaseOrderId       String
  quoteLineItemId       String?
  quantity              Int
  status                String   @default("PENDING") // PENDING, SOURCED, PURCHASED, SHIPPED, RECEIVED, MISSING, CANCELLED
  sourcedById           String?
  sourcedAt             DateTime?
  sourceUrl             String?
  vendorName            String?
  purchasedById         String?
  purchasedAt           DateTime?
  orderNumber           String?
  expectedDeliveryDate  DateTime?
  receivedAt            DateTime?
  receivedQuantity      Int      @default(0)
  trackingNumber        String?
  confirmationScreenshot String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  purchaseOrder         PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  quoteLineItem         QuoteLineItem? @relation(fields: [quoteLineItemId], references: [id])
  sourcedBy             User?          @relation("ItemSourcer", fields: [sourcedById], references: [id])
  purchasedBy           User?          @relation("ItemPurchaser", fields: [purchasedById], references: [id])
  discrepancies         Discrepancy[]
  shipmentItems         ShipmentItem[]

  @@map("purchase_order_items")
}

model Alert {
  id                String   @id @default(cuid())
  userId            String
  type              String   // MISSING_ITEM, OVERDUE, ATTENTION_REQUIRED, DEADLINE, SYSTEM
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  readAt            DateTime?
  severity          String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id])

  @@map("alerts")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  action     String
  details    String?  // JSON string
  createdAt  DateTime @default(now())

  // Relations
  user       User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Note {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user       User     @relation(fields: [userId], references: [id])

  @@map("notes")
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorName      String
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, MATCHED, PARTIAL, DISPUTED, PAID
  receivedAt      DateTime @default(now())
  dueDate         DateTime?
  fileUrl         String?
  purchaseOrderId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  lineItems       InvoiceLineItem[]
  matchRecords    MatchRecord[]
  discrepancies   Discrepancy[]
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  // Relations
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model MatchRecord {
  id              String    @id @default(cuid())
  purchaseOrderId String
  invoiceId       String
  status          String    @default("PENDING") // AUTO_MATCHED, PARTIAL_MATCH, MISMATCH, MANUAL_OVERRIDE
  matchedAt       DateTime?
  notes           String?
  toleranceUsed   Float?
  details         String?   // JSON string with match details
  createdAt       DateTime  @default(now())

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("match_records")
}

model ApprovalRule {
  id             String   @id @default(cuid())
  name           String
  entityType     String   // PURCHASE_ORDER, INVOICE, REQUEST
  conditionField String   // e.g. "totalAmount", "priority"
  conditionOp    String   // gt, lt, gte, lte, eq
  conditionValue String   // threshold value as string
  approverRole   String?  // role that can approve
  approverUserId String?  // specific user that can approve
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  approvalRequests ApprovalRequest[]
  approverUser     User?    @relation("ApprovalRuleApprover", fields: [approverUserId], references: [id])

  @@map("approval_rules")
}

model ApprovalRequest {
  id            String    @id @default(cuid())
  entityType    String
  entityId      String
  ruleId        String?
  requestedById String
  approverId    String?
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED, ESCALATED
  requestedAt   DateTime  @default(now())
  resolvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  rule          ApprovalRule? @relation(fields: [ruleId], references: [id])
  requestedBy   User          @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approver      User?         @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@map("approval_requests")
}

model Discrepancy {
  id                  String    @id @default(cuid())
  purchaseOrderId     String
  purchaseOrderItemId String?
  invoiceId           String?
  type                String    // QUANTITY_MISMATCH, PRICE_MISMATCH, WRONG_ITEM, DAMAGED, MISSING, EXTRA
  expectedValue       String
  actualValue         String
  status              String    @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, ESCALATED
  reportedById        String
  resolvedById        String?
  resolvedAt          DateTime?
  resolutionNotes     String?
  photoUrls           String?   // JSON array of URLs
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  invoice             Invoice?           @relation(fields: [invoiceId], references: [id])
  reportedBy          User               @relation("DiscrepancyReporter", fields: [reportedById], references: [id])
  resolvedBy          User?              @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])

  @@map("discrepancies")
}

model Shipment {
  id              String    @id @default(cuid())
  purchaseOrderId String
  method          String    // CARRIER, MANUAL
  carrierName     String?
  trackingNumber  String?
  scheduledDate   DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  podFileUrl      String?
  podStatus       String    @default("NONE") // NONE, UPLOADED, VERIFIED
  status          String    @default("PREPARING") // PREPARING, READY, IN_TRANSIT, DELIVERED, FAILED, INVESTIGATING
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items           ShipmentItem[]

  @@map("shipments")
}

model ShipmentItem {
  id                  String @id @default(cuid())
  shipmentId          String
  purchaseOrderItemId String
  quantity            Int
  boxNumber           Int?

  // Relations
  shipment            Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])

  @@map("shipment_items")
}

model ClientInvoice {
  id              String    @id @default(cuid())
  purchaseOrderId String
  clientId        String
  shipmentId      String?
  invoiceNumber   String    @unique
  totalAmount     Float
  status          String    @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  sentAt          DateTime?
  paidAt          DateTime?
  dueDate         DateTime?
  podVerified     Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  client          Client        @relation(fields: [clientId], references: [id])

  @@map("client_invoices")
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
