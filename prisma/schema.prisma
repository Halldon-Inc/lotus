// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          String   @default("SALES") // ADMIN, MANAGER, SALES, PROCUREMENT, OPERATIONS
  avatar        String?
  department    String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  assignedClients   Client[]       @relation("AssignedRep")
  createdRequests   Request[]      @relation("RequestCreator")
  assignedRequests  Request[]      @relation("RequestAssignee")
  createdQuotes     Quote[]        @relation("QuoteCreator")
  verifiedPOs       PurchaseOrder[] @relation("POVerifier")
  sourcedItems      PurchaseOrderItem[] @relation("ItemSourcer")
  purchasedItems    PurchaseOrderItem[] @relation("ItemPurchaser")
  alerts            Alert[]
  activityLogs      ActivityLog[]
  notes             Note[]
  approvalRules     ApprovalRule[]     @relation("ApprovalRuleApprover")
  approvalRequests  ApprovalRequest[]  @relation("ApprovalRequester")
  approvalDecisions ApprovalRequest[]  @relation("ApprovalApprover")
  reportedDiscrepancies Discrepancy[]  @relation("DiscrepancyReporter")
  resolvedDiscrepancies Discrepancy[]  @relation("DiscrepancyResolver")
  inventoryMovements    InventoryMovement[] @relation("InventoryMovements")
  totpSecret            String?
  totpEnabled           Boolean  @default(false)
  passwordHash          String?
  attachments           Attachment[] @relation("UserAttachments")
  rfqs                  RFQ[]        @relation("RFQCreator")
  approvedChangeOrders  ChangeOrder[] @relation("ChangeOrderApprover")

  @@map("users")
}

model Client {
  id              String   @id @default(cuid())
  name            String
  type            String   // SCHOOL, GOVERNMENT, HEALTHCARE, NONPROFIT, CORPORATE
  address         String?
  city            String?
  state           String?
  zip             String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  fiscalYearStart DateTime?
  spendingLimit   Float?
  hubspotId       String?
  assignedRepId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  assignedRep     User?           @relation("AssignedRep", fields: [assignedRepId], references: [id])
  requests        Request[]
  quotes          Quote[]
  purchaseOrders  PurchaseOrder[]
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  quickbooksId    String?
  clientInvoices  ClientInvoice[]
  budgets         Budget[]
  contracts       Contract[]
  rfqs            RFQ[]

  @@map("clients")
}

model Budget {
  id            String   @id @default(cuid())
  clientId      String
  fiscalYear    Int
  department    String?
  totalBudget   Float    @default(0)
  encumbered    Float    @default(0)
  spent         Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id])
  @@unique([clientId, fiscalYear, department])
  @@map("budgets")
}

model Request {
  id            String   @id @default(cuid())
  clientId      String
  assignedToId  String?
  createdById   String
  subject       String
  description   String
  source        String   @default("MANUAL") // EMAIL, MANUAL, HUBSPOT
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status        String   @default("NEW") // NEW, ASSIGNED, IN_PROGRESS, QUOTED, CLOSED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  client        Client   @relation(fields: [clientId], references: [id])
  assignedTo    User?    @relation("RequestAssignee", fields: [assignedToId], references: [id])
  createdBy     User     @relation("RequestCreator", fields: [createdById], references: [id])
  quotes        Quote[]

  @@map("requests")
}

model Quote {
  id            String   @id @default(cuid())
  requestId     String
  clientId      String
  createdById   String
  quoteNumber   String   @unique
  totalAmount   Float    @default(0)
  status        String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  validUntil    DateTime?
  sentAt        DateTime?
  hubspotQuoteId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  request       Request     @relation(fields: [requestId], references: [id])
  client        Client      @relation(fields: [clientId], references: [id])
  createdBy     User        @relation("QuoteCreator", fields: [createdById], references: [id])
  lineItems     QuoteLineItem[]
  purchaseOrder PurchaseOrder?

  @@map("quotes")
}

model QuoteLineItem {
  id            String   @id @default(cuid())
  quoteId       String
  productName   String
  description   String?
  specifications String?  // JSON string for color, size, material, etc.
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  sourceUrl     String?
  vendorName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  purchaseOrderItems PurchaseOrderItem[]

  @@map("quote_line_items")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  quoteId         String?  @unique
  clientId        String
  poNumber        String   @unique
  totalAmount     Float
  status          String   @default("RECEIVED") // RECEIVED, VERIFIED, NEEDS_CORRECTION, RESUBMITTED, IN_PURCHASING, PARTIALLY_FULFILLED, FULFILLED, DELIVERED
  receivedAt      DateTime @default(now())
  verifiedById    String?
  discrepancyNotes String?
  scheduledDeliveryDate DateTime?
  deliveryMethod  String?
  rejectionReason String?
  rejectionCount  Int      @default(0)
  notes           String?
  procurementMethod       String?
  cooperativeContractRef  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  quote           Quote?            @relation(fields: [quoteId], references: [id])
  client          Client            @relation(fields: [clientId], references: [id])
  verifiedBy      User?             @relation("POVerifier", fields: [verifiedById], references: [id])
  items           PurchaseOrderItem[]
  invoices        Invoice[]
  matchRecords    MatchRecord[]
  discrepancies   Discrepancy[]
  shipments       Shipment[]
  clientInvoices  ClientInvoice[]
  rmas            RMA[]
  changeOrders    ChangeOrder[]
  isBlanketPO     Boolean       @default(false)
  blanketTotal    Float?
  blanketUsed     Float?
  masterPOId      String?

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                    String   @id @default(cuid())
  purchaseOrderId       String
  quoteLineItemId       String?
  quantity              Int
  status                String   @default("PENDING") // PENDING, SOURCED, PURCHASED, SHIPPED, RECEIVED, MISSING, CANCELLED
  sourcedById           String?
  sourcedAt             DateTime?
  sourceUrl             String?
  vendorName            String?
  purchasedById         String?
  purchasedAt           DateTime?
  orderNumber           String?
  expectedDeliveryDate  DateTime?
  receivedAt            DateTime?
  receivedQuantity      Int      @default(0)
  trackingNumber        String?
  confirmationScreenshot String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  purchaseOrder         PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  quoteLineItem         QuoteLineItem? @relation(fields: [quoteLineItemId], references: [id])
  sourcedBy             User?          @relation("ItemSourcer", fields: [sourcedById], references: [id])
  purchasedBy           User?          @relation("ItemPurchaser", fields: [purchasedById], references: [id])
  discrepancies         Discrepancy[]
  shipmentItems         ShipmentItem[]

  @@map("purchase_order_items")
}

model Alert {
  id                String   @id @default(cuid())
  userId            String
  type              String   // MISSING_ITEM, OVERDUE, ATTENTION_REQUIRED, DEADLINE, SYSTEM
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  readAt            DateTime?
  severity          String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id])

  @@map("alerts")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  action     String
  details    String?  // JSON string
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  // Relations
  user       User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Note {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user       User     @relation(fields: [userId], references: [id])

  @@map("notes")
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  vendorName      String
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, MATCHED, PARTIAL, DISPUTED, PAID
  receivedAt      DateTime @default(now())
  dueDate         DateTime?
  fileUrl         String?
  purchaseOrderId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quickbooksId    String?

  // Relations
  lineItems       InvoiceLineItem[]
  matchRecords    MatchRecord[]
  discrepancies   Discrepancy[]
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  // Relations
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model MatchRecord {
  id              String    @id @default(cuid())
  purchaseOrderId String
  invoiceId       String
  status          String    @default("PENDING") // AUTO_MATCHED, PARTIAL_MATCH, MISMATCH, MANUAL_OVERRIDE
  matchedAt       DateTime?
  notes           String?
  toleranceUsed   Float?
  details         String?   // JSON string with match details
  createdAt       DateTime  @default(now())

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("match_records")
}

model ApprovalRule {
  id             String   @id @default(cuid())
  name           String
  entityType     String   // PURCHASE_ORDER, INVOICE, REQUEST
  conditionField String   // e.g. "totalAmount", "priority"
  conditionOp    String   // gt, lt, gte, lte, eq
  conditionValue String   // threshold value as string
  approverRole   String?  // role that can approve
  approverUserId String?  // specific user that can approve
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  approvalRequests ApprovalRequest[]
  approverUser     User?    @relation("ApprovalRuleApprover", fields: [approverUserId], references: [id])

  @@map("approval_rules")
}

model ApprovalRequest {
  id            String    @id @default(cuid())
  entityType    String
  entityId      String
  ruleId        String?
  requestedById String
  approverId    String?
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED, ESCALATED
  requestedAt   DateTime  @default(now())
  resolvedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  rule          ApprovalRule? @relation(fields: [ruleId], references: [id])
  requestedBy   User          @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approver      User?         @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@map("approval_requests")
}

model Discrepancy {
  id                  String    @id @default(cuid())
  purchaseOrderId     String
  purchaseOrderItemId String?
  invoiceId           String?
  type                String    // QUANTITY_MISMATCH, PRICE_MISMATCH, WRONG_ITEM, DAMAGED, MISSING, EXTRA
  expectedValue       String
  actualValue         String
  status              String    @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, ESCALATED
  reportedById        String
  resolvedById        String?
  resolvedAt          DateTime?
  resolutionNotes     String?
  photoUrls           String?   // JSON array of URLs
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  purchaseOrder       PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  invoice             Invoice?           @relation(fields: [invoiceId], references: [id])
  reportedBy          User               @relation("DiscrepancyReporter", fields: [reportedById], references: [id])
  resolvedBy          User?              @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])

  @@map("discrepancies")
}

model Shipment {
  id              String    @id @default(cuid())
  purchaseOrderId String
  method          String    // CARRIER, MANUAL
  carrierName     String?
  trackingNumber  String?
  scheduledDate   DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  podFileUrl      String?
  podStatus       String    @default("NONE") // NONE, UPLOADED, VERIFIED
  status          String    @default("PREPARING") // PREPARING, READY, IN_TRANSIT, DELIVERED, FAILED, INVESTIGATING
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  items           ShipmentItem[]

  @@map("shipments")
}

model ShipmentItem {
  id                  String @id @default(cuid())
  shipmentId          String
  purchaseOrderItemId String
  quantity            Int
  boxNumber           Int?

  // Relations
  shipment            Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])

  @@map("shipment_items")
}

model ClientInvoice {
  id              String    @id @default(cuid())
  purchaseOrderId String
  clientId        String
  shipmentId      String?
  invoiceNumber   String    @unique
  totalAmount     Float
  status          String    @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  sentAt          DateTime?
  paidAt          DateTime?
  dueDate         DateTime?
  podVerified     Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  quickbooksId    String?

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  client          Client        @relation(fields: [clientId], references: [id])

  @@map("client_invoices")
}

model ImportSession {
  id         String   @id @default(cuid())
  userId     String
  entityType String?
  fileName   String?
  headers    String
  data       String
  status     String   @default("PENDING")
  results    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("import_sessions")
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model QuickBooksConnection {
  id             String    @id @default(cuid())
  realmId        String    @unique
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  companyName    String?
  isActive       Boolean   @default(true)
  connectedAt    DateTime  @default(now())
  lastSyncAt     DateTime?
  syncStatus     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("quickbooks_connections")
}

model InventoryItem {
  id               String   @id @default(cuid())
  name             String
  sku              String?  @unique
  description      String?
  category         String?
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  reorderPoint     Int      @default(0)
  location         String?
  unitCost         Float?
  lastRestockedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  movements        InventoryMovement[]

  @@map("inventory_items")
}

model InventoryMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  type            String   // RECEIVED, ALLOCATED, SHIPPED, RETURNED, ADJUSTMENT
  quantity        Int
  referenceType   String?  // PURCHASE_ORDER, QUOTE, MANUAL
  referenceId     String?
  notes           String?
  performedById   String
  createdAt       DateTime @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  performedBy     User @relation("InventoryMovements", fields: [performedById], references: [id])

  @@map("inventory_movements")
}

model Attachment {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  uploadedById  String
  createdAt     DateTime @default(now())
  uploadedBy    User     @relation("UserAttachments", fields: [uploadedById], references: [id])
  @@map("attachments")
}

model Contract {
  id              String    @id @default(cuid())
  clientId        String
  contractNumber  String    @unique
  title           String
  vendor          String?
  startDate       DateTime
  endDate         DateTime
  totalValue      Float?
  status          String    @default("ACTIVE")
  renewalDate     DateTime?
  terms           String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          Client    @relation(fields: [clientId], references: [id])
  @@map("contracts")
}

model RFQ {
  id              String    @id @default(cuid())
  rfqNumber       String    @unique
  clientId        String
  title           String
  description     String?
  dueDate         DateTime
  status          String    @default("OPEN")
  createdById     String
  selectedVendor  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          Client    @relation(fields: [clientId], references: [id])
  createdBy       User      @relation("RFQCreator", fields: [createdById], references: [id])
  responses       RFQResponse[]
  @@map("rfqs")
}

model RFQResponse {
  id          String   @id @default(cuid())
  rfqId       String
  vendorName  String
  totalAmount Float
  notes       String?
  fileUrl     String?
  selected    Boolean  @default(false)
  createdAt   DateTime @default(now())
  rfq         RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  @@map("rfq_responses")
}

model RMA {
  id                  String    @id @default(cuid())
  purchaseOrderId     String
  purchaseOrderItemId String?
  rmaNumber           String    @unique
  reason              String
  status              String    @default("REQUESTED")
  vendorResponse      String?
  refundAmount        Float?
  creditMemoRef       String?
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  @@map("rmas")
}

model ChangeOrder {
  id              String   @id @default(cuid())
  purchaseOrderId String
  changeNumber    Int
  reason          String
  fieldChanged    String
  oldValue        String
  newValue        String
  approvedById    String?
  approvedAt      DateTime?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  approvedBy      User?    @relation("ChangeOrderApprover", fields: [approvedById], references: [id])
  @@map("change_orders")
}

model VendorScorecard {
  id              String   @id @default(cuid())
  vendorName      String
  period          String
  deliveryScore   Float    @default(0)
  qualityScore    Float    @default(0)
  pricingScore    Float    @default(0)
  responseScore   Float    @default(0)
  overallScore    Float    @default(0)
  totalOrders     Int      @default(0)
  onTimeRate      Float    @default(0)
  defectRate      Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([vendorName, period])
  @@map("vendor_scorecards")
}
