# Database
DATABASE_URL="postgresql://username:password@localhost:5432/lotus_connect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# App Configuration
NODE_ENV=development

# QuickBooks Integration
QB_CLIENT_ID=your-quickbooks-client-id
QB_CLIENT_SECRET=your-quickbooks-client-secret
QB_REDIRECT_URI=http://localhost:3000/api/v1/quickbooks/callback
QB_ENVIRONMENT=sandbox

# HubSpot Integration
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token

# Email Notifications
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Lotus Connect <notifications@lotusconnect.com>"
